@using System.Linq
@model InternFreelance.ViewModels.StudentDashboardVm

<div class="dash-page">
    <div class="dash-page-header">
        <div>
            <div class="dash-page-title">Student overview</div>
            <p class="dash-page-subtitle">
                Here’s what’s happening with your applications.
            </p>
        </div>

        <div class="dash-stat-pills">
            <div class="dash-stat-pill">
                Total apps: @Model.TotalApplications
            </div>
            <div class="dash-stat-pill">
                Active: @Model.ActiveCount
            </div>
            <div class="dash-stat-pill">
                Completed: @Model.CompletedCount
            </div>
        </div>
    </div>

    <!-- Top row: hero + recommended -->
    <div class="dash-row">
        <!-- Hero card -->
        <section class="dash-card dash-card--hero">
            <span class="dash-tag-pill">
                <span>Student</span>
                <span>Live dashboard</span>
            </span>

            <h2>Overview</h2>
            <p style="font-size:0.9rem; opacity:0.9; max-width:22rem;">
                Track active applications, finished projects and new opportunities in one place.
            </p>

            <div class="dash-hero-metrics">
                <div>
                    <div class="dash-hero-metric-label">Active applications</div>
                    <div class="dash-hero-metric-value">@Model.ActiveCount</div>
                </div>
                <div>
                    <div class="dash-hero-metric-label">Completed projects</div>
                    <div class="dash-hero-metric-value">@Model.CompletedCount</div>
                </div>
                <div>
                    <div class="dash-hero-metric-label">Total applications</div>
                    <div class="dash-hero-metric-value">@Model.TotalApplications</div>
                </div>
            </div>
        </section>

        <!-- Recommended projects -->
        <section class="dash-card dash-card--side">
            <div class="dash-card-header">
                <div>
                    <div class="dash-card-title">Recommended projects</div>
                    <div class="dash-card-subtitle">
                        Fresh briefs you can apply to right now.
                    </div>
                </div>
                <a asp-controller="Projects" asp-action="Index" class="dash-link-muted">
                    Browse all →
                </a>
            </div>

            @if (Model.RecommendedProjects != null && Model.RecommendedProjects.Any())
            {
                <div class="dash-project-list">
                    @foreach (var p in Model.RecommendedProjects)
                    {
                        <div class="dash-project-item">
                            <div>
                                <div>@p.Title</div>
                                <div class="dash-project-meta">
                                    Status: @p.Status
                                </div>
                            </div>
                            <a asp-controller="Projects"
                               asp-action="Details"
                               asp-route-id="@p.Id"
                               class="dash-btn-ghost">
                                View
                            </a>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="dash-card-subtitle">No recommended projects right now.</p>
            }
        </section>
    </div>

    <!-- Notifications / recent updates -->
    <div class="dash-row dash-row--full">
        <section class="dash-card dash-card--side">
            <div class="dash-card-header">
                <div>
                    <div class="dash-card-title">Recent updates</div>
                    <div class="dash-card-subtitle">
                        New decisions on your applications.
                    </div>
                </div>
            </div>

            @if (Model.RecentUpdates != null && Model.RecentUpdates.Any())
            {
                <div class="dash-project-list">
                    @foreach (var app in Model.RecentUpdates)
                    {
                        var isAccepted = app.Status == "Accepted";
                        <div class="dash-project-item">
                            <div>
                                <div>@app.Project?.Title</div>
                                <div class="dash-project-meta">
                                    @app.StatusUpdatedAt?.ToString("dd MMM, HH:mm") • @app.Status
                                </div>
                            </div>
                            <span class="dash-status-pill @(isAccepted ? "dash-status--accepted" : "dash-status--pending")">
                                @app.Status
                            </span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="dash-card-subtitle">No new updates yet.</p>
            }
        </section>
    </div>

    <!-- Active applications -->
    <div class="dash-row dash-row--full">
        <section class="dash-card">
            <div class="dash-card-header">
                <div>
                    <div class="dash-card-title">Active applications</div>
                    <div class="dash-card-subtitle">
                        Pending, accepted, or assigned projects.
                    </div>
                </div>
            </div>

            @if (Model.ActiveApplications != null && Model.ActiveApplications.Any())
            {
                <div style="overflow-x:auto;">
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>Project</th>
                                <th>Status</th>
                                <th>Applied</th>
                                <th>Submission</th>  <!-- new -->
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var app in Model.ActiveApplications)
                            {
                                var status = app.Status ?? string.Empty;
                                var statusClass =
                                status == "Completed" ? "dash-status--completed" :
                                status == "Accepted" ? "dash-status--accepted" :
                                status == "Assigned" ? "dash-status--assigned" :
                                "dash-status--pending";

                                <tr>
                                    <td>@app.Project?.Title</td>

                                    <td>
                                        <span class="dash-status-pill @statusClass">@status</span>
                                    </td>

                                    <td>@app.AppliedAt.ToString("dd MMM yyyy")</td>

                                    <!-- SUBMISSION COLUMN -->
                                    <td>
                                        @if (app.Status == "Accepted" || app.Status == "Assigned")
                                        {
                                            <a asp-controller="Student"
                                               asp-action="SubmitWork"
                                               asp-route-id="@app.Id"
                                               class="dash-link-muted">
                                                @(app.SubmittedAt == null ? "Submit work" : "Update submission")
                                            </a>

                                            @if (app.SubmittedAt != null)
                                            {
                                                <div class="dash-project-meta">
                                                    Submitted on @app.SubmittedAt.Value.ToString("dd MMM yyyy")
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <span class="dash-project-meta">Waiting for SME decision</span>
                                        }
                                    </td>

                                    <!-- Existing View link -->
                                    <td>
                                        <a asp-controller="Projects"
                                           asp-action="Details"
                                           asp-route-id="@app.ProjectId"
                                           class="dash-link-muted">
                                            View →
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="dash-card-subtitle">You don’t have any active applications yet.</p>
            }
        </section>
    </div>

