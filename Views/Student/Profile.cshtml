@using System.Linq
@using InternFreelance.Models
@model AppUser

@{
    ViewData["Title"] = "Student profile – " + (Model.FullName ?? Model.Email);

    var completedApps = ViewBag.CompletedApps as List<ProjectApplication> ?? new List<ProjectApplication>();
    bool isOwner = ViewBag.IsOwner == null || ViewBag.IsOwner == true;

    // Safe avatar initial
    var nameSource = !string.IsNullOrWhiteSpace(Model.FullName)
        ? Model.FullName
        : (Model.Email ?? "?");

    var avatarInitial = string.IsNullOrWhiteSpace(nameSource)
        ? "?"
        : nameSource.Trim()[0].ToString().ToUpper();
}

<style>
    .sp-page-bg {
        background: #F3F4F6;
    }

    .sp-hero-card {
        border-radius: 18px;
        border: 1px solid #E5E7EB;
        box-shadow: 0 16px 40px rgba(148, 163, 184, 0.25);
        background: linear-gradient(135deg, #FFFFFF 0%, #EEF2FF 40%, #ECFEFF 100%);
    }

    .sp-avatar {
        width: 56px;
        height: 56px;
        border-radius: 999px;
        background: #1D4ED8;
        color: #FFFFFF;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.4rem;
    }

    .sp-tag {
        display: inline-flex;
        align-items: center;
        padding: 3px 10px;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 500;
        margin-right: 4px;
        margin-bottom: 4px;
        background: #E5E7EB;
        color: #374151;
    }

    .sp-tag-primary {
        background: #DBEAFE;
        color: #1D4ED8;
    }

    .sp-label {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #6B7280;
        font-weight: 600;
    }

    .sp-value {
        font-size: 0.93rem;
        color: #111827;
    }

    .sp-stat-card {
        border-radius: 14px;
        border: 1px solid #E5E7EB;
        background: #FFFFFF;
        padding: 10px 14px;
        text-align: left;
    }

    .sp-stat-number {
        font-size: 1.25rem;
        font-weight: 700;
        color: #111827;
    }

    .sp-section-card {
        border-radius: 16px;
        border: 1px solid #E5E7EB;
        background: #FFFFFF;
        box-shadow: 0 12px 28px rgba(148, 163, 184, 0.18);
    }

    .sp-section-title {
        font-size: 1rem;
        font-weight: 600;
        margin-bottom: 4px;
    }

    .sp-section-sub {
        font-size: 0.82rem;
        color: #6B7280;
    }

    .sp-pill-status {
        border-radius: 999px;
        font-size: 0.75rem;
        padding: 3px 9px;
    }

    .sp-pill-status-accepted {
        background: #DCFCE7;
        color: #166534;
    }

    .sp-pill-status-completed {
        background: #DBEAFE;
        color: #1E3A8A;
    }

    .sp-pill-status-pending {
        background: #E5E7EB;
        color: #374151;
    }

    .sp-link-muted {
        font-size: 0.85rem;
        color: #4B5563;
        text-decoration: none;
    }

        .sp-link-muted:hover {
            text-decoration: underline;
        }

    .sp-skills-list span {
        margin-right: 6px;
        margin-bottom: 6px;
    }
</style>

<div class="sp-page-bg">
    <div class="container py-4">

        <!-- Top: profile hero + stats -->
        <div class="row gy-3 mb-4">
            <div class="col-lg-8">
                <div class="card sp-hero-card border-0">
                    <div class="card-body">
                        <div class="d-flex flex-wrap align-items-start gap-3">
                            <div class="sp-avatar">
                                @avatarInitial
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between flex-wrap gap-2">
                                    <div>
                                        <h3 class="mb-1">
                                            @(!string.IsNullOrWhiteSpace(Model.FullName) ? Model.FullName : Model.Email)
                                        </h3>
                                        <div class="text-muted small mb-1">
                                            @Model.Email
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(Model.Headline))
                                        {
                                            <div class="text-muted">
                                                @Model.Headline
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="text-muted small">
                                                Aspiring intern – profile ready for real SME projects.
                                            </div>
                                        }
                                    </div>

                                    <div class="text-end">
                                        @if (isOwner)
                                        {
                                            <a asp-controller="Student"
                                               asp-action="EditProfile"
                                               class="btn btn-primary btn-sm mb-2">
                                                Edit profile
                                            </a>
                                        }
                                        <div class="small text-muted">
                                            Role: Student
                                        </div>
                                    </div>
                                </div>

                                <!-- quick meta -->
                                <div class="row mt-3 g-3">
                                    <div class="col-md-4">
                                        <div class="sp-stat-card">
                                            <div class="sp-label">Completed / accepted</div>
                                            <div class="sp-stat-number">
                                                @completedApps.Count
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="sp-stat-card">
                                            <div class="sp-label">University</div>
                                            <div class="sp-value">
                                                @(string.IsNullOrWhiteSpace(Model.University)
                                                                                                ? "Not specified"
                                                                                                : Model.University)
                                            </div>
                                        </div>
                                    </div>
                                </div> <!-- /row -->
                            </div> <!-- /flex-grow-1 -->
                        </div> <!-- /d-flex -->
                    </div> <!-- /card-body -->
                </div> <!-- /card -->
            </div> <!-- /col-lg-8 -->
            <!-- Right: links -->
            <div class="col-lg-4">
                <div class="card sp-section-card border-0 mb-3">
                    <div class="card-body">
                        <div class="sp-section-title mb-1">Links</div>
                        <div class="sp-section-sub mb-2">
                            Public links that SMEs can quickly skim.
                        </div>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-1">
                                <span class="sp-label d-block mb-1">Portfolio</span>
                                @if (!string.IsNullOrWhiteSpace(Model.PortfolioUrl))
                                {
                                    <a href="@Model.PortfolioUrl" target="_blank" class="sp-link-muted">
                                        @Model.PortfolioUrl
                                    </a>
                                }
                                else
                                {
                                    <span class="sp-value text-muted">Not added</span>
                                }
                            </li>
                            <li class="mb-1">
                                <span class="sp-label d-block mb-1">GitHub</span>
                                @if (!string.IsNullOrWhiteSpace(Model.GithubUrl))
                                {
                                    <a href="@Model.GithubUrl" target="_blank" class="sp-link-muted">
                                        @Model.GithubUrl
                                    </a>
                                }
                                else
                                {
                                    <span class="sp-value text-muted">Not added</span>
                                }
                            </li>
                            <li class="mb-1">
                                <span class="sp-label d-block mb-1">LinkedIn</span>
                                @if (!string.IsNullOrWhiteSpace(Model.LinkedInUrl))
                                {
                                    <a href="@Model.LinkedInUrl" target="_blank" class="sp-link-muted">
                                        @Model.LinkedInUrl
                                    </a>
                                }
                                else
                                {
                                    <span class="sp-value text-muted">Not added</span>
                                }
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="card sp-section-card border-0">
                    <div class="card-body">
                        <div class="sp-section-title mb-1">Contact</div>
                        <div class="sp-section-sub mb-2">
                            Preferred way to reach this student.
                        </div>
                        <div class="sp-label mb-1">Email</div>
                        <div class="sp-value">@Model.Email</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom: bio + skills + completed projects -->
        <div class="row gy-3">
            <div class="col-lg-8">
                <div class="card sp-section-card border-0 mb-3">
                    <div class="card-body">
                        <div class="sp-section-title">About</div>
                        <div class="sp-section-sub mb-2">
                            Short summary written by the student.
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.Bio))
                        {
                            <p class="mb-0" style="font-size:0.9rem; color:#374151;">
                                @Model.Bio
                            </p>
                        }
                        else
                        {
                            <p class="mb-0 text-muted" style="font-size:0.9rem;">
                                This student hasn’t added a bio yet.
                            </p>
                        }
                    </div>
                </div>

                <div class="card sp-section-card border-0">
                    <div class="card-body">
                        <div class="sp-section-title">Completed / accepted projects</div>
                        <div class="sp-section-sub mb-2">
                            Projects from SMEs that this student has been accepted to or completed.
                        </div>

                        @if (!completedApps.Any())
                        {
                            <div class="text-muted small">
                                No accepted or completed applications yet.
                            </div>
                        }
                        else
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var app in completedApps)
                                {
                                    var pillClass = app.Status == "Completed"
                                    ? "sp-pill-status sp-pill-status-completed"
                                    : "sp-pill-status sp-pill-status-accepted";

                                    <div class="list-group-item px-0">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <div class="fw-semibold">
                                                    @app.Project?.Title ?? "Project"
                                                </div>
                                                <div class="small text-muted">
                                                    @app.Project?.Skills
                                                </div>
                                            </div>
                                            <div>
                                                <span class="@pillClass">
                                                    @app.Status
                                                </span>
                                            </div>
                                        </div>
                                        <div class="small text-muted mt-1">
                                            Applied: @app.AppliedAt.ToString("yyyy-MM-dd")
                                        </div>
                                    </div>
                                    @if (app.CertificatePath != null)
                                    {
                                        <a href="@app.CertificatePath"
                                           target="_blank"
                                           class="btn btn-sm btn-success ms-2">
                                            View Certificate
                                        </a>
                                    }
                                }
                               

                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card sp-section-card border-0">
                    <div class="card-body">
                        <div class="sp-section-title">Skills</div>
                        <div class="sp-section-sub mb-2">
                            Technologies and focus areas the student is comfortable with.
                        </div>

                        <div class="sp-skills-list">
                            @if (!string.IsNullOrWhiteSpace(Model.SkillsCsv))
                            {
                                var skills = Model.SkillsCsv
                                .Split(',', ';')
                                .Select(s => s.Trim())
                                .Where(s => !string.IsNullOrWhiteSpace(s))
                                .ToList();

                                if (skills.Any())
                                {
                                    foreach (var s in skills)
                                    {
                                        <span class="sp-tag sp-tag-primary">@s</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">No skills listed yet.</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted small">No skills listed yet.</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
