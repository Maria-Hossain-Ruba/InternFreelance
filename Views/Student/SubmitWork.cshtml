@model InternFreelance.ViewModels.SubmitWorkViewModel


@{
    ViewData["Title"] = "Submit Work";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h2 class="mb-1">Submit Work</h2>
                    <p class="text-muted mb-4">
                        Project: <strong>@Model.ProjectTitle</strong>
                    </p>

                    <form asp-action="SubmitWork" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ApplicationId" />

                        <div class="mb-3">
                            <label asp-for="GithubUrl" class="form-label"></label>
                            <input asp-for="GithubUrl" class="form-control" placeholder="https://github.com/username/repo" />
                            <span asp-validation-for="GithubUrl" class="text-danger"></span>
                            <small class="text-muted">
                                Please provide the GitHub repository URL for your project.
                            </small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LiveDemoUrl" class="form-label"></label>
                            <input asp-for="LiveDemoUrl" class="form-control" placeholder="https://your-live-demo.com" />
                            <span asp-validation-for="LiveDemoUrl" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="4"
                                      placeholder="Explain how to run the project, important notes for the SME, etc."></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary px-4">
                            Submit Work
                        </button>
                        <a asp-action="Dashboard" class="btn btn-outline-secondary ms-2">
                            Cancel
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
