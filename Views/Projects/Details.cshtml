@model InternFreelance.Models.Project

@{
    ViewData["Title"] = "Project Details";

    bool canApply = ViewBag.CanApply as bool? ?? false;
    bool isLoggedIn = ViewBag.IsLoggedIn as bool? ?? false;
    bool isStudent = ViewBag.IsStudent as bool? ?? false;
    bool projectOpen = ViewBag.ProjectOpen as bool? ?? false;
}

<div class="row mt-3">
    <div class="col-md-8">
        <h3>@Model.Title</h3>
        <span class="badge bg-secondary">@Model.Status</span>

        <p class="mt-3">@Model.Description</p>

        <p class="small text-muted">
            Skills: @Model.Skills<br />
            Budget: @(Model.Budget.HasValue ? "$" + Model.Budget.Value.ToString("0") : "Flexible")
        </p>

        <p class="small">
            Posted by: <strong>@Model.Owner?.FullName</strong>
            <span class="text-muted">(@Model.CreatedAt.ToShortDateString())</span>
        </p>

        @if (TempData["Msg"] != null)
        {
            <div class="alert alert-info">@TempData["Msg"]</div>
        }

        @* SME brief (optional) *@
        @if (!string.IsNullOrEmpty(Model.BriefFilePath))
        {
            <p class="small mb-3">
                <strong>Brief:</strong>
                <a href="@Model.BriefFilePath" target="_blank">
                    @(string.IsNullOrEmpty(Model.BriefOriginalFileName)
                                    ? "Download brief"
                                    : Model.BriefOriginalFileName)
                </a>
            </p>
        }

        <!-- APPLY LOGIC -->
        @if (canApply)
        {
            <hr />
            <h5>Apply as student</h5>

            <form asp-controller="Projects"
                  asp-action="Apply"
                  method="post"
                  enctype="multipart/form-data">

                @Html.AntiForgeryToken()
                <input type="hidden" name="projectId" value="@Model.Id" />

                <div class="mb-3">
                    <label class="form-label">Cover letter</label>
                    <textarea name="coverLetter"
                          class="form-control"
                          rows="4"
                          placeholder="Explain why you’re a good fit..."></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label">Upload CV (PDF, DOCX)</label>
                    <input type="file"
                           name="cvFile"
                           class="form-control"
                           accept=".pdf,.doc,.docx"
                           required />
                </div>

                <button type="submit" class="btn btn-success">
                    Apply with CV
                </button>
            </form>
        }
        else if (!isLoggedIn)
        {
            <div class="alert alert-warning mt-3">
                Please <a asp-controller="Account" asp-action="Login">log in</a> as a
                <strong>student</strong> to apply.
            </div>
        }
        else if (!isStudent)
        {
            <div class="alert alert-secondary mt-3">
                You are signed in, but only students can apply for projects.
            </div>
        }
        else if (!projectOpen)
        {
            <div class="alert alert-secondary mt-3">
                This project is no longer open for applications.
            </div>
        }
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="card-title">Applicants</h6>

                @if (Model.Applications != null && Model.Applications.Count > 0)
                {
                    <ul class="list-unstyled small">
                        @foreach (var app in Model.Applications.OrderByDescending(a => a.AppliedAt))
                        {
                            <li class="mb-2">
                                <strong>@app.Student?.FullName</strong>
                                <span class="badge bg-secondary ms-1">@app.Status</span><br />
                                <span class="text-muted">@app.AppliedAt.ToShortDateString()</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted small">No applications yet.</p>
                }
            </div>
        </div>
    </div>
</div>
