@using InternFreelance.Models
@model InternFreelance.Models.Project

@{
    ViewData["Title"] = "Applications for " + Model.Title;
    var apps = Model.Applications ?? new List<ProjectApplication>();

    var pendingCount = apps.Count(a => a.Status == "Pending");
    var acceptedCount = apps.Count(a => a.Status == "Accepted");
    var rejectedCount = apps.Count(a => a.Status == "Rejected");
}

<style>
    .apps-page-bg {
        background: #F3F4F6;
    }

    .apps-card {
        border-radius: 18px;
        border: 1px solid #E5E7EB;
        box-shadow: 0 14px 30px rgba(148, 163, 184, 0.18);
    }

    .apps-header-title {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 4px;
    }

    .apps-header-sub {
        font-size: 0.9rem;
        color: #6B7280;
    }

    .apps-pill {
        display: inline-flex;
        align-items: center;
        padding: 3px 10px;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 600;
        margin-left: 6px;
        background-color: #E5E7EB;
        color: #374151;
    }

    .apps-pill-pending {
        background-color: #FEF3C7;
        color: #92400E;
    }

    .apps-pill-accepted {
        background-color: #DCFCE7;
        color: #166534;
    }

    .apps-pill-rejected {
        background-color: #FEE2E2;
        color: #991B1B;
    }

    .apps-row-accepted {
        background-color: #F0FDF4;
    }

    .apps-row-rejected {
        background-color: #FEF2F2;
    }

    .apps-row-pending {
        background-color: #EFF6FF;
    }

        .apps-row-accepted:hover,
        .apps-row-rejected:hover,
        .apps-row-pending:hover {
            filter: brightness(0.98);
        }

    .apps-status-badge {
        border-radius: 999px;
        font-size: 0.75rem;
        padding: 4px 10px;
    }

    .apps-status-accepted {
        background-color: #16A34A;
        color: #FFFFFF;
    }

    .apps-status-rejected {
        background-color: #DC2626;
        color: #FFFFFF;
    }

    .apps-status-assigned {
        background-color: #3B82F6;
        color: #FFFFFF;
    }

    .apps-status-pending {
        background-color: #4B5563;
        color: #F9FAFB;
    }

    .apps-student-name {
        font-weight: 600;
        font-size: 0.95rem;
    }

    .apps-student-email {
        font-size: 0.8rem;
        color: #6B7280;
    }

    .apps-cover {
        font-size: 0.82rem;
        color: #4B5563;
    }

    .apps-cover-empty {
        color: #9CA3AF;
        font-style: italic;
    }

    .apps-table thead th {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #6B7280;
    }
</style>

<div class="apps-page-bg">
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h2 class="apps-header-title mb-1">Applications</h2>
                <p class="apps-header-sub mb-1">
                    Project: <strong>@Model.Title</strong>
                </p>
                <div class="apps-header-sub">
                    <span class="apps-pill apps-pill-pending">Pending @pendingCount</span>
                    <span class="apps-pill apps-pill-accepted">Accepted @acceptedCount</span>
                    <span class="apps-pill apps-pill-rejected">Rejected @rejectedCount</span>
                </div>
            </div>
            <a asp-controller="Dashboard"
               asp-action="Sme"
               class="btn btn-outline-secondary">
                ← Back to Dashboard
            </a>
        </div>

        @if (TempData["Msg"] != null)
        {
            <div class="alert alert-info">@TempData["Msg"]</div>
        }

        @if (!apps.Any())
        {
            <div class="alert alert-light border">
                No students have applied for this project yet.
            </div>
        }
        else
        {
            <div class="card border-0 apps-card">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Student Applications (@apps.Count)</h5>
                    <span class="text-muted small">
                        Review candidates, open their profiles and decide who to work with.
                    </span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 apps-table">
                            <thead class="table-light">
                                <tr>
                                    <th>Student</th>
                                    <th>Applied At</th>
                                    <th>Status</th>
                                    <th>CV</th>
                                    <th>Cover Letter</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in apps.OrderByDescending(a => a.AppliedAt))
                                {
                                    var rowClass = app.Status == "Accepted"
                                    ? "apps-row-accepted"
                                    : app.Status == "Rejected"
                                    ? "apps-row-rejected"
                                    : app.Status == "Pending"
                                    ? "apps-row-pending"
                                    : "";

                                    var statusClass = app.Status == "Accepted" ? "apps-status-badge apps-status-accepted"
                                    : app.Status == "Rejected" ? "apps-status-badge apps-status-rejected"
                                    : app.Status == "Assigned" ? "apps-status-badge apps-status-assigned"
                                    : "apps-status-badge apps-status-pending";

                                    <tr class="@rowClass">
                                        <td>
                                            <div class="apps-student-name">
                                                @(app.Student?.FullName ?? app.Student?.Email ?? "Student")
                                            </div>
                                            <div class="apps-student-email">@app.Student?.Email</div>
                                        </td>
                                        <td>@app.AppliedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>
                                            <span class="@statusClass">@app.Status</span>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(app.CvPath))
                                            {
                                                <a asp-controller="Projects"
                                                   asp-action="DownloadCv"
                                                   asp-route-applicationId="@app.Id">
                                                    Download CV
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="text-muted">No CV</span>
                                            }
                                        </td>
                                        <td style="max-width: 260px;">
                                            @if (!string.IsNullOrWhiteSpace(app.CoverLetter))
                                            {
                                                <div class="apps-cover">
                                                    @app.CoverLetter
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="apps-cover apps-cover-empty">
                                                    No cover letter
                                                </div>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <!-- View profile is always available -->
                                            <a asp-controller="Student"
                                               asp-action="ViewProfile"
                                               asp-route-studentId="@app.StudentId"
                                               class="btn btn-sm btn-outline-secondary me-1">
                                                View profile
                                            </a>

                                            @if (app.Status == "Pending")
                                            {
                                                <form asp-controller="Projects"
                                                      asp-action="ApproveApplication"
                                                      method="post"
                                                      class="d-inline">
                                                    <input type="hidden" name="applicationId" value="@app.Id" />
                                                    <button type="submit" class="btn btn-sm btn-success">
                                                        Approve
                                                    </button>
                                                </form>

                                                <form asp-controller="Projects"
                                                      asp-action="RejectApplication"
                                                      method="post"
                                                      class="d-inline ms-1">
                                                    <input type="hidden" name="applicationId" value="@app.Id" />
                                                    <button type="submit" class="btn btn-sm btn-danger">
                                                        Reject
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">No actions available</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
