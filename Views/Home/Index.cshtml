@{
    ViewData["Title"] = "Find real SME projects";
}

<div class="home-hero">
    <div class="container">
        <div class="row align-items-center g-4">
            <!-- LEFT: hero text -->
            <div class="col-lg-6">
                <p class="hero-kicker mb-2">InternFreelance • Student marketplace</p>
                <h1 class="hero-title">
                    Get <span class="accent">real projects</span><br />
                    from real <span class="accent">SMEs</span>.
                </h1>
                <p class="hero-subtitle mt-3">
                    Not fake assignments. Actual work from startups and SMEs that
                    turns into a solid portfolio and internship experience.
                </p>

                <!-- search bar -->
                <form class="hero-search mt-4" asp-controller="Projects" asp-action="Index" method="get">
                    <div class="input-group input-group-lg">
                        <input type="text"
                               name="q"
                               class="form-control hero-search-input"
                               placeholder="Search projects e.g. &quot;React landing page&quot; or &quot;Logo design&quot;" />
                        <button class="btn btn-accent fw-semibold" type="submit">
                            Search
                        </button>
                    </div>
                    <div class="hero-tags mt-2">
                        Trending:
                        <button type="submit" name="q" value="frontend" class="btn btn-tag">Frontend</button>
                        <button type="submit" name="q" value="ui ux" class="btn btn-tag">UI/UX</button>
                        <button type="submit" name="q" value="asp.net" class="btn btn-tag">ASP.NET</button>
                        <button type="submit" name="q" value="data entry" class="btn btn-tag">Data entry</button>
                    </div>
                </form>

                <!-- stats -->
                <div class="hero-stats mt-4">
                    <div class="stat-item">
                        <div class="stat-number">40+</div>
                        <div class="stat-label">SME partners</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number">120+</div>
                        <div class="stat-label">Projects completed</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number">3</div>
                        <div class="stat-label">Sample roles built-in</div>
                    </div>
                </div>

                <div class="mt-4 d-flex flex-wrap gap-3">
                    <a asp-controller="Projects" asp-action="Index" class="btn btn-accent btn-lg">
                        Browse live projects
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg">
                        Join as student
                    </a>
                </div>
            </div>

            <!-- RIGHT: hero card -->
            <div class="col-lg-6">
                <div class="hero-card shadow-lg">
                    <div class="hero-card-header">
                        <span class="dot dot-green"></span>
                        <span class="dot dot-yellow"></span>
                        <span class="dot dot-red"></span>
                        <span class="hero-card-title">Live project board</span>
                    </div>
                    <div class="hero-card-body">
                        <div class="fake-project-row">
                            <div>
                                <div class="fp-title">Landing page for travel SaaS</div>
                                <div class="fp-meta">UI/UX • HTML • Bootstrap</div>
                            </div>
                            <div class="fp-budget">$150</div>
                        </div>
                        <div class="fake-project-row">
                            <div>
                                <div class="fp-title">Simple ASP.NET CRUD dashboard</div>
                                <div class="fp-meta">C# • ASP.NET • SQL</div>
                            </div>
                            <div class="fp-budget">$200</div>
                        </div>
                        <div class="fake-project-row">
                            <div>
                                <div class="fp-title">Social media content pack</div>
                                <div class="fp-meta">Canva • Copywriting</div>
                            </div>
                            <div class="fp-budget">$80</div>
                        </div>

                        <div class="text-end mt-3">
                            <a asp-controller="Projects" asp-action="Index" class="link-light small">
                                View all projects &rarr;
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- trusted strip -->
<section class="trusted-strip">
    <div class="container d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div class="trusted-label">Trusted by SMEs & student clubs from</div>
        <div class="trusted-logos">
            <span>BrightTech</span>
            <span>CampusHub</span>
            <span>Alpha Labs</span>
            <span>StartX</span>
        </div>
    </div>
</section>

<!-- categories -->
<section class="section-block">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="section-title">Browse by category</h2>
            <a asp-controller="Projects" asp-action="Index" class="link-light small">
                See all &rarr;
            </a>
        </div>
        <div class="row g-3">
            <div class="col-6 col-md-3">
                <a asp-controller="Projects" asp-action="Index" asp-route-q="web"
                   class="category-card">
                    <div class="category-title">Web development</div>
                    <div class="category-sub">Landing pages, dashboards</div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Projects" asp-action="Index" asp-route-q="design"
                   class="category-card">
                    <div class="category-title">Design &amp; UI</div>
                    <div class="category-sub">Logos, Figma, social</div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Projects" asp-action="Index" asp-route-q="data"
                   class="category-card">
                    <div class="category-title">Data &amp; scripts</div>
                    <div class="category-sub">Reports, automation</div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Projects" asp-action="Index" asp-route-q="content"
                   class="category-card">
                    <div class="category-title">Content</div>
                    <div class="category-sub">Blog posts, marketing</div>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- how it works -->
<section class="section-block">
    <div class="container">
        <h2 class="section-title mb-4">How it works</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-number">1</div>
                    <h5>Sign up as a student</h5>
                    <p>Create a simple profile with your skills and year of study.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-number">2</div>
                    <h5>Apply to SME projects</h5>
                    <p>Send a short cover letter and link to your work or GitHub.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-number">3</div>
                    <h5>Deliver & get proof</h5>
                    <p>Submit your work link, get marked as completed, and use it in your CV.</p>
                </div>
            </div>
        </div>
    </div>
</section>
