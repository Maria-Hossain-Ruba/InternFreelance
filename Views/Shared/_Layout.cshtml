@using Microsoft.AspNetCore.Http
@using InternFreelance.Data
@using InternFreelance.Models
@inject InternFreelance.Data.AppDbContext db

@{
    Layout = null;

    // -------- figure out if user is logged in via Session --------
    var idString = Context.Session.GetString("UserId");
    var isLoggedIn = !string.IsNullOrEmpty(idString);

    RoleType? currentRole = null;

    if (isLoggedIn && int.TryParse(idString, out var uid))
    {
        // Use the injected DbContext (configured in Program.cs via appsettings.json)
        var user = db.UsersTable.Find(uid);
        if (user != null)
        {
            currentRole = user.Role;
        }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewBag.Title - InternFreelance</title>

    <!-- Bootstrap -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif !important;
        }
    </style>
</head>

<body>
    <!-- ======================== -->
    <!--       TOP NAV BAR       -->
    <!-- ======================== -->
    <nav class="navbar navbar-expand-lg bg-white shadow-sm py-3">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                InternFreelance
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Projects" asp-action="Index">Projects</a>
                    </li>

                    @if (isLoggedIn && currentRole == RoleType.Student)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Student">
                                Student Dashboard
                            </a>
                        </li>
                    }

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Student" asp-action="Profile">My profile</a>
                    </li>

                    @if (isLoggedIn && currentRole == RoleType.SME)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Sme">
                                SME Dashboard
                            </a>
                        </li>
                    }
                </ul>

                <ul class="navbar-nav ms-auto">
                    @if (isLoggedIn)
                    {
                        <li class="nav-item">
                            <form asp-controller="Account"
                                  asp-action="Logout"
                                  method="post"
                                  class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-dark px-3">
                                    Log out
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-dark px-3"
                               asp-controller="Account"
                               asp-action="Login">
                                Login
                            </a>
                        </li>
                        <li class="nav-item ms-2">
                            <a class="btn btn-outline-dark px-3"
                               asp-controller="Account"
                               asp-action="Register">
                                Sign up
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    @if (Context.Session.GetString("UserRole") == "Admin")
    {
        <li class="nav-item">
            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Admin</a>
        </li>
    }


    <!-- ======================== -->
    <!--       MAIN CONTENT       -->
    <!-- ======================== -->
    <main role="main" class="container-fluid px-0">
        @RenderBody()
    </main>

    <!-- ======================== -->
    <!--        FOOTER            -->
    <!-- ======================== -->
    <footer class="py-4 mt-5 border-top bg-white">
        <div class="container text-center text-muted">
            <p class="mb-0">© @DateTime.Now.Year InternFreelance. All rights reserved.</p>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
