@using InternFreelance.Models
@using Microsoft.AspNetCore.Http
@using Microsoft.AspNetCore.Http.Features

@{
    // Try to get session only if it exists in the pipeline
    var sessionFeature = Context.Features.Get<ISessionFeature>();
    var session = sessionFeature?.Session;

    string? userRole = null;
    string? userName = null;

    if (session != null)
    {
        userRole = session.GetString("UserRole");
        userName = session.GetString("UserName");
    }
}


<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - InternFreelance</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm main-nav">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                Intern<span class="accent">Freelance</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Projects" asp-action="Index">Browse Projects</a>
                    </li>

                    @if (userRole == "SME" || userRole == "Admin")
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Projects" asp-action="MyProjects">My SME Projects</a>
                        </li>
                    }
                    @if (userRole == "Student")
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Projects" asp-action="MyApplications">My Applications</a>
                        </li>
                    }
                    @if (userRole == "Admin")
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a>
                        </li>
                    }
                </ul>

                <ul class="navbar-nav ms-auto">
                    @if (string.IsNullOrEmpty(userRole))
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-light btn-sm me-2"
                               asp-controller="Account" asp-action="Login">Log in</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-accent btn-sm"
                               asp-controller="Account" asp-action="Register">Sign up</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item d-flex align-items-center me-3">
                            <span class="text-light small">
                                @userName
                                <span class="badge bg-accent ms-1">@userRole</span>
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-light btn-sm"
                               asp-controller="Account" asp-action="Logout">Logout</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="hero-gradient">
        <div class="container py-4">
            @RenderBody()
        </div>
    </div>

    <footer class="footer text-center py-3">
        <span class="text-muted small">
            © @DateTime.Now.Year InternFreelance – Student-built internship marketplace
        </span>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
