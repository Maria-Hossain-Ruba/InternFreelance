@model IEnumerable<InternFreelance.Models.Project>

@{
    ViewData["Title"] = "Admin Dashboard";
}

<h3 class="mt-3">Admin Dashboard</h3>

<div class="row mt-3">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="label">Users</div>
            <div class="value">@ViewBag.UserCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="label">Projects</div>
            <div class="value">@ViewBag.ProjectCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="label">Open</div>
            <div class="value">@ViewBag.OpenProjects</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="label">Completed</div>
            <div class="value">@ViewBag.CompletedProjects</div>
        </div>
    </div>
</div>

<h5 class="mt-4">Latest Projects</h5>
<table class="table table-sm">
    <thead>
        <tr>
            <th>Title</th>
            <th>SME</th>
            <th>Status</th>
            <th>Created</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Title</td>
                <td>@p.Owner?.FullName</td>
                <td>@p.Status</td>
                <td>@p.CreatedAt.ToShortDateString()</td>
            </tr>
        }
    </tbody>
</table>
